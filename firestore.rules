rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'name',
          'displayName',
          'problemsCompleted',
          'leaderboardVisible',
          'age13Confirmed',
          'termsAcceptedAt',
          'privacyPolicyVersion',
          'createdAt'
        ])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.problemsCompleted == 0
        && request.resource.data.leaderboardVisible == false
        && request.resource.data.age13Confirmed == true
        && request.resource.data.privacyPolicyVersion is string;

      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'displayName',
          'leaderboardVisible'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.problemsCompleted is int
        && request.resource.data.problemsCompleted >= 0
        && request.resource.data.leaderboardVisible is bool;

      allow delete: if false;
    }

    // Roleplay records contain transcripts and AI feedback. Only the trusted
    // server (Firebase Admin SDK) may access them.
    match /roleplays/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
